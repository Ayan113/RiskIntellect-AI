# ============================================================
# Environment Variables — Copy to .env and fill in values
# ============================================================

# OpenAI API Key (required for LLM layer)
OPENAI_API_KEY=sk-your-key-here

# Application
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# MLflow
MLFLOW_TRACKING_URI=mlruns

# API
API_HOST=0.0.0.0
API_PORT=8000
